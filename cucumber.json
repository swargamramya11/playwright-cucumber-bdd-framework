{
    "default": {
        "formatOptions": {
            "resultsDir": "test-results/allure/allure-results",
            "snippetInterface": "async-await"
        },
        "paths": [
            "src/test/features/**/*.feature"
        ],
        "dryRun": false,
        "require": [
            "utils/envLoader.ts",
            "src/test/steps/*.ts",
            "src/hooks/hooks.ts"
        ],
        "requireModule": [
            "ts-node/register"
        ],
        "format": [
            "progress-bar",
            "html:test-results/reports/html-report.html",
            "json:test-results/reports/html-report.json",
            "rerun:@rerun.txt"
        ],
        "parallel": 1,
        "retry": 0
    },
    "rerun": {
        "formatOptions": {
            "resultsDir": "reports/allure-results",
            "snippetInterface": "async-await"
        },
        "dryRun": false,
        "require": [
            "utils/envLoader.ts",
            "src/test/steps/*.ts",
            "src/hooks/hooks.ts"
        ],
        "requireModule": [
            "ts-node/register"
        ],
        "format": [
            "progress-bar",
            "html:test-results/reports/html-report.html",
            "json:test-results/reports/html-report.json",
            "rerun:@rerun.txt"
        ],
        "parallel": 2
    }
}